# Environment variables for Hermes Agent
# Copy this file to .env and fill in your real values

# Tavily API Key (for web search and content extraction)
# Get yours at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# GitHub Token (for GitHub API access)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Todoist API Token
# Get yours at: https://todoist.com/app/settings/integrations
TODOIST_API_TOKEN=your_todoist_token_here

# BrowserAct API Key (for stealth browser automation)
# Get yours at: https://www.browseract.com/
BROWSERACT_API_KEY=your_browseract_key_here

# Feishu/Lark Configuration
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Obsidian Vault Path
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian Vault
